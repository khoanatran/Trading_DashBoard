{
  "name": "trading-performance-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "launch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/launch-dashboard.ps1",
    "shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-desktop-shortcut.ps1",
    "lint": "next lint",
    "remigrate-media": "npx --yes tsx scripts/remigrate-trade-media.ts",
    "github:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-github-backup.ps1",
    "github:pull": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/github-pull.ps1",
    "import:mt5": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/import-mt5-reports.ps1",
    "github:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/github-backup.ps1",
    "github:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/github-sync.ps1",
    "github:auto-sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/github-auto-sync.ps1",
    "github:auto-sync:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-auto-sync-task.ps1",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^0.454.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.1.3",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.5.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "^16.2.6"
  }
}
