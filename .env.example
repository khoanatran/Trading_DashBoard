# GitHub backup (optional — enabled by default when Git is installed)
# GITHUB_BACKUP_ENABLED=true
# GITHUB_BACKUP_REMOTE=https://github.com/khoanatran/Trading_DashBoard.git
# GITHUB_BACKUP_BRANCH=main
# GITHUB_BACKUP_DEBOUNCE_MS=8000
# GITHUB_SYNC_PULL_ON_LAUNCH=true
# GIT_PATH=C:\Program Files\Git\cmd\git.exe
# GITHUB_BACKUP_USER_NAME=khoanatran
# GITHUB_BACKUP_USER_EMAIL=khoanatran@users.noreply.github.com
#
# On launch the dashboard auto-pulls from GitHub (scripts/github-pull.ps1 + /api/github-sync).
